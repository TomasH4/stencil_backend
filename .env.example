# PostgreSQL connection string (e.g. from Supabase or local postgres)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@host:port/database"

# Direct URL is often needed if using connection pooling (like Supabase)
DIRECT_URL="postgresql://user:password@host:port/database"

# Secret used to sign JWT tokens — use a long random string
JWT_SECRET="super-secret-random-string"

# JWT expiration time (e.g. 1h, 7d, 24h)
JWT_EXPIRES_IN=1h

# Port where the server will listen locally
PORT=3000

# Supabase Storage Credentials (for portfolio images, avatars, etc.)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-or-service-role-key"
